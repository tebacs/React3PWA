generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model Item {
  id               Int      @id @default(autoincrement())
  name             String
  category         String
  image            String
  shortDescription String
  fullDescription  String
  technicalSpecs   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
