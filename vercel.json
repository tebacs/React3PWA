{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "scripts": [
    {
      "dev": "node index.js", 
      "vercel-build": "npx prisma generate",
      "build": "npx prisma generate"
    }
  ]
}